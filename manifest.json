{
  "name": "scan-and-ask",
  "version": "1.1.0",
  "description": "Scan & Ask — 拍张照片/扫描件，AI 帮你从文档里找答案。基于 PaddleOCR + OpenVINO 的本地 OCR + RAG 智能问答 Skill，支持合同/病历/身份证等扫描件，全程数据不出机。",
  "author": "OpenClaw",
  "tags": ["AIPC", "RAG", "OpenVINO", "INT4", "privacy", "local-first", "document-analysis"],
  "category": "text-analysis",
  "language": "zh",
  "license": "Apache-2.0",
  "model": "ollama/qwen3.5:9b",
  "dependencies": [
    "openvino>=2025.3",
    "openvino-genai>=2025.3",
    "faiss-cpu>=1.7.4",
    "pymupdf>=1.23.0",
    "numpy>=1.24.0",
    "transformers>=4.40.0",
    "requests>=2.31.0"
  ],
  "hardware": {
    "min_ram_gb": 8,
    "recommended_ram_gb": 16,
    "supported_devices": ["CPU", "GPU", "NPU"],
    "recommended_device": "CPU"
  },
  "tools": [
    {
      "name": "parse_document",
      "description": "解析上传的文档（PDF/扫描件/图片/文本），提取文本内容并分块。PDF 扫描件和图片自动调用本地 PaddleOCR 识别文字。返回文档ID和文本块数量。",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "文档的本地文件路径，支持PDF和TXT格式"
          },
          "chunk_size": {
            "type": "integer",
            "description": "分块大小（字符数），默认500",
            "default": 500
          }
        },
        "required": ["file_path"]
      },
      "entry_point": "tools/doc_parser.py:main"
    },
    {
      "name": "build_index",
      "description": "对已解析的文档构建本地向量索引，用于后续检索。使用 OpenVINO 优化的 embedding 模型。",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档ID，由 parse_document 返回"
          }
        },
        "required": ["doc_id"]
      },
      "entry_point": "tools/vector_store.py:main"
    },
    {
      "name": "query_document",
      "description": "对已构建索引的文档进行语义检索，返回与查询最相关的文本片段。",
      "parameters": {
        "type": "object",
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "文档ID，由 parse_document 返回"
          },
          "query": {
            "type": "string",
            "description": "用户查询问题"
          },
          "top_k": {
            "type": "integer",
            "description": "返回最相关的片段数量，默认3",
            "default": 3
          }
        },
        "required": ["doc_id", "query"]
      },
      "entry_point": "tools/rag_query.py:main"
    },
    {
      "name": "ocr_image",
      "description": "对图片（PNG/JPG/BMP/TIFF）或扫描件 PDF 进行本地 OCR 文字识别，使用 PaddleOCR PP-OCRv6，支持中英文混合识别。返回识别文本和置信度。",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "图片或扫描件 PDF 的本地路径"
          },
          "engine": {
            "type": "string",
            "description": "OCR 后端：auto（优先 OpenVINO，失败回退 PaddlePaddle）、openvino、paddle",
            "default": "auto"
          }
        },
        "required": ["file_path"]
      },
      "entry_point": "tools/ocr.py:main"
    }
  ]
}
